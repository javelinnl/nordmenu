#!/bin/bash
if [ "$#" -gt 0 ]; then
    exec nordvpn "$@"
fi

tput civis
trap 'tput cnorm; clear' EXIT

# ANSI Escape Codes
COLOR_ACTIVE="\e[1;34m"
COLOR_INACTIVE="\e[0;37m"
COLOR_HEADER_CONNECTED="\e[1;34m"
COLOR_HEADER_DISCONNECTED="\e[1;31m"
COLOR_BORDER="\e[0;90m"
COLOR_TITLEICON_CONNECTED="\e[1;32m"
COLOR_TITLEICON_DISCONNECTED="\e[1;31m"
COLOR_TITLE="\e[1;37m"
COLOR_GOOD="\e[1;32m"
COLOR_BAD="\e[1;31m"
COLOR_RESET="\e[0m"

# Menu Options
options=("Auto"
         "Netherlands"
         "Austria"
         "US East Coast"
         "India"
         "Reconnect"
         "Disconnect")

# NordVPN Locations Map
declare -A locations=(
    ["Auto"]=""
    ["Netherlands"]="Netherlands"
    ["Austria"]="Austria"
    ["US East Coast"]="United_States"
    ["India"]="India"
    ["Reconnect"]="RECONNECT_CMD"
    ["Disconnect"]="DISCONNECT_CMD"
)

# State
current_selection=0
menu_size=${#options[@]}
lastlocation=""

# Layout
MENU_TOP=1
FIRST_ITEM_LINE=5
OUTPUT_START_LINE=$((FIRST_ITEM_LINE + menu_size * 2 + 1))
ACTION_DIVIDER_AFTER=$((menu_size - 3))

move_cursor() {
    echo -ne "\e[$1;1H"
}

clear_from_cursor_down() {
    echo -ne "\e[J"
}

draw_header() {
    local status
    status=$(nordvpn status 2>/dev/null)

    move_cursor 1

    if echo "$status" | grep -qi "disconnected"; then
        echo -e " ${COLOR_HEADER_DISCONNECTED}╭──────────────────────────────────────╮${COLOR_RESET}"
        echo -e " ${COLOR_HEADER_DISCONNECTED}│  ${COLOR_TITLEICON_DISCONNECTED}󱙱  ${COLOR_TITLE}NordVPN disconnected             ${COLOR_HEADER_DISCONNECTED}│${COLOR_RESET}"
        echo -e " ${COLOR_HEADER_DISCONNECTED}╰──────────────────────────────────────╯${COLOR_RESET}"
    else
        echo -e " ${COLOR_HEADER_CONNECTED}╭──────────────────────────────────────╮${COLOR_RESET}"
        echo -e " ${COLOR_HEADER_CONNECTED}│  ${COLOR_TITLEICON_CONNECTED}󰌾  ${COLOR_TITLE}NordVPN connected                ${COLOR_HEADER_CONNECTED}│${COLOR_RESET}"
        echo -e " ${COLOR_HEADER_CONNECTED}╰──────────────────────────────────────╯${COLOR_RESET}"
    fi
}

draw_menu_item() {
    local i=$1
    local option="${options[$i]}"
    local item_text="  ${option} "
    local padded_text
    padded_text=$(printf "%-35s" "$item_text")

    if [[ $i -eq $current_selection ]]; then
        echo -e " ${COLOR_BORDER}│${COLOR_ACTIVE}  »${padded_text}${COLOR_RESET}${COLOR_BORDER}│${COLOR_RESET}"
    else
        echo -e " ${COLOR_BORDER}│   ${COLOR_INACTIVE}${padded_text}${COLOR_RESET}${COLOR_BORDER}│${COLOR_RESET}"
    fi
}

draw_menu() {
    draw_header

    echo -e " ${COLOR_BORDER}╭──────────────────────────────────────╮${COLOR_RESET}"

    for ((i=0; i<menu_size; i++)); do
        draw_menu_item "$i"

        if [[ $i -lt $((menu_size - 1)) ]]; then
            if [[ $i -eq $ACTION_DIVIDER_AFTER ]]; then
                echo -e " ${COLOR_BORDER}╞══════════════════════════════════════╡${COLOR_RESET}"
            else
                echo -e " ${COLOR_BORDER}├──────────────────────────────────────┤${COLOR_RESET}"
            fi
        fi
    done

    echo -e " ${COLOR_BORDER}╰──────────────────────────────────────╯${COLOR_RESET}"
    echo -e "   ${COLOR_ACTIVE}↑/↓${COLOR_RESET} Navigate  ${COLOR_ACTIVE}⏎${COLOR_RESET} Select  ${COLOR_ACTIVE}Q${COLOR_RESET} Quit"
}

update_selection() {
    local new_selection=$1
    current_selection=$new_selection
    move_cursor "$MENU_TOP"
    draw_menu
    move_cursor "$OUTPUT_START_LINE"
}

show_output_header() {
    move_cursor "$OUTPUT_START_LINE"
    clear_from_cursor_down
    echo
}

run_selected_option() {
    local selected_option="${options[$current_selection]}"
    local location="${locations[$selected_option]}"

    show_output_header

    if [[ "$selected_option" == "Disconnect" ]]; then
        echo -e "    ${COLOR_TITLE}⏱  Disconnecting VPN...${COLOR_RESET}"
        nordvpn disconnect > /dev/null 2>&1
            if [ $? -eq 0 ]; then
                echo -e "    ${COLOR_GOOD}✓  Success.${COLOR_RESET}"
            else
                echo -e "    ${COLOR_BAD}✕  Failed.${COLOR_RESET}"
            fi

    elif [[ "$selected_option" == "Reconnect" ]]; then
        if [[ -z "$lastlocation" ]]; then
            echo -e "    ${COLOR_BAD}   No previous location selected.${COLOR_RESET}"
        else
            echo -e "    ${COLOR_TITLE}⏱  Reconnecting to ${lastselected}...${COLOR_RESET}"
            nordvpn disconnect  > /dev/null 2>&1
            sleep 1
            nordvpn connect "$lastlocation" > /dev/null 2>&1
            if [ $? -eq 0 ]; then
                echo -e "    ${COLOR_GOOD}✓  Success.${COLOR_RESET}"
            else
                echo -e "    ${COLOR_BAD}✕  Failed.${COLOR_RESET}"
            fi
        fi

    else
        if [[ -z "$location" ]]; then
            echo -e "    ${COLOR_TITLE}⏱  Auto connecting...${COLOR_RESET}"
            nordvpn connect > /dev/null 2>&1
            if [ $? -eq 0 ]; then
                echo -e "    ${COLOR_GOOD}✓  Success.${COLOR_RESET}"
            else
                echo -e "    ${COLOR_BAD}✕  Failed.${COLOR_RESET}"
            fi
        else
            lastlocation="$location"
            lastselected="$selected_option"
            echo -e "    ${COLOR_TITLE}⏱  Connecting to ${selected_option}...${COLOR_RESET}"
            nordvpn connect "$location" > /dev/null 2>&1
            if [ $? -eq 0 ]; then
                echo -e "    ${COLOR_GOOD}✓  Success.${COLOR_RESET}"
            else
                echo -e "    ${COLOR_BAD}✕  Failed.${COLOR_RESET}"
            fi
        fi
    fi

    move_cursor "$MENU_TOP"
    draw_menu
    move_cursor "$OUTPUT_START_LINE"
}

# Initial draw
clear
draw_menu
move_cursor "$OUTPUT_START_LINE"

# Main loop
while true; do
    read -sn 1 key
    [[ "$key" == $'\x1b' ]] && read -sn 2 -t 1 k2 && key+="$k2"

    case "$key" in
        $'\x1b[A')
            new_selection=$((current_selection - 1))
            [[ $new_selection -lt 0 ]] && new_selection=$((menu_size - 1))
            update_selection "$new_selection"
            ;;

        $'\x1b[B')
            new_selection=$((current_selection + 1))
            [[ $new_selection -ge $menu_size ]] && new_selection=0
            update_selection "$new_selection"
            ;;

        '')
            run_selected_option
            ;;

        q|Q)
            clear
            exit 0
            ;;
    esac
done
